# Ignore everything in docsify (it's regenerated by scripts/convert.js)
/outliyr-framework/docsify/*

# But keep hand-maintained files: index.html, _navbar.md, .nojekyll, and the
# assets folder (favicon, logo, styles.css). convert.js does not touch these.
!/outliyr-framework/docsify/index.html
!/outliyr-framework/docsify/_navbar.md
!/outliyr-framework/docsify/.nojekyll
!/outliyr-framework/docsify/assets/

# Google Search Console verification file (hand-maintained, served at site root)
!/outliyr-framework/docsify/google638d0b83dfae9043.html


# Ignore .idea files
/.idea/*